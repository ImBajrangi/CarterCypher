{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    { "src": "/images/(.*)", "dest": "/images/$1", "headers": { "cache-control": "public, max-age=31536000, immutable" } },
    { "src": "/assets/(.*)", "dest": "/assets/$1", "headers": { "cache-control": "public, max-age=31536000, immutable" } },
    { "handle": "filesystem" }
  ]
}
